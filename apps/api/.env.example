# Copy this file to .env and fill in real values.
# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/prospectfinder?schema=public"

# Port the NestJS API listens on (defaults to 3001).
PORT=3001

# Google Places API (New) key — https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=""

# Google Geocoding API key (can be the same Google Maps Platform key as above,
# provided the Geocoding API is enabled on it) — https://console.cloud.google.com/apis/credentials
GOOGLE_GEOCODING_API_KEY=""

# Origin allowed by CORS (the Next.js frontend).
WEB_ORIGIN=http://localhost:3000

# Caches every distinct Google Places/Geocoding request under fixtures/google-api/*.json,
# so repeated dev/test runs replay the saved response instead of billing a new call.
# Set to "false" to always hit the real API — and always set it to "false" in production,
# where serving a stale cached result to a real user would be wrong.
GOOGLE_API_CACHE=true

# Which SearchStrategy powers POST /search:
# - "grid" (default): thorough recursive grid search, many Google calls.
# - "development": one cheap text search per known commune (see communes.data.ts).
SEARCH_STRATEGY_MODE=grid
