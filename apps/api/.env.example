# Copy this file to .env and fill in real values.
# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/prospectfinder?schema=public"

# Port the NestJS API listens on (defaults to 3001).
PORT=3001

# Google Places API (New) key — https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=""

# Origin allowed by CORS (the Next.js frontend).
WEB_ORIGIN=http://localhost:3000
